<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Супер Гонки - GameAI</title>
    <style>
        body { margin: 0; overflow: hidden; background: #000; font-family: 'Segoe UI', sans-serif; }
        canvas { display: block; margin: 0 auto; }
        #ui { position: absolute; top: 20px; left: 20px; color: #fff; font-size: 24px; text-shadow: 2px 2px 4px #000; pointer-events: none; }
        #startScreen, #gameOverScreen { 
            position: absolute; top: 0; left: 0; width: 100%; height: 100%; 
            background: rgba(0,0,0,0.8); display: flex; flex-direction: column; 
            align-items: center; justify-content: center; color: #fff; z-index: 10;
        }
        .hidden { display: none !important; }
        h1 { font-size: 4rem; margin-bottom: 1rem; color: #00ff88; text-shadow: 0 0 20px #00ff88; }
        button { 
            padding: 1rem 3rem; font-size: 1.5rem; background: #00ff88; border: none; 
            border-radius: 10px; cursor: pointer; font-weight: bold; transition: 0.3s;
        }
        button:hover { transform: scale(1.1); box-shadow: 0 0 30px #00ff88; }
        .controls { margin-top: 2rem; color: #aaa; font-size: 1.2rem; }
    </style>
</head>
<body>
    <div id="ui">SCORE: <span id="score">0</span></div>
    
    <div id="startScreen">
        <h1>🏎️ СУПЕР ГОНКИ</h1>
        <button onclick="startGame()">НАЧАТЬ ИГРУ</button>
        <div class="controls">Управление: ← → или A D</div>
    </div>

    <div id="gameOverScreen" class="hidden">
        <h1>GAME OVER</h1>
        <p style="font-size: 2rem; margin-bottom: 2rem;">Твой счет: <span id="finalScore">0</span></p>
        <button onclick="resetGame()">ИГРАТЬ СНОВА</button>
    </div>

    <canvas id="gameCanvas"></canvas>

    <script>
        const canvas = document.getElementById('gameCanvas');
        const ctx = canvas.getContext('2d');
        
        // Настройки канваса
        canvas.width = window.innerWidth > 800 ? 800 : window.innerWidth;
        canvas.height = 600;
        
        // Состояние игры
        let gameRunning = false;
        let score = 0;
        let speed = 5;
        let roadOffset = 0;
        
        // Игрок
        const player = { x: canvas.width / 2 - 25, y: canvas.height - 120, width: 50, height: 90, color: '#00ff88' };
        
        // Враги
        let enemies = [];
        
        // Управление
        const keys = {};
        window.addEventListener('keydown', e => keys[e.key] = true);
        window.addEventListener('keyup', e => keys[e.key] = false);
        
        // Функция рисования ДЕТАЛЬНОЙ МАШИНЫ
        function drawCar(x, y, w, h, color, isPlayer = false) {
            // Тень
            ctx.fillStyle = 'rgba(0,0,0,0.5)';
            ctx.fillRect(x + 5, y + 5, w, h);
            
            // Колеса (4 штуки)
            ctx.fillStyle = '#111';
            ctx.fillRect(x - 2, y + 10, 6, 18); // Левое переднее
            ctx.fillRect(x + w - 4, y + 10, 6, 18); // Правое переднее
            ctx.fillRect(x - 2, y + h - 28, 6, 18); // Левое заднее
            ctx.fillRect(x + w - 4, y + h - 28, 6, 18); // Правое заднее
            
            // Диски колес
            ctx.fillStyle = '#555';
            ctx.fillRect(x, y + 13, 2, 12);
            ctx.fillRect(x + w - 2, y + 13, 2, 12);
            ctx.fillRect(x, y + h - 25, 2, 12);
            ctx.fillRect(x + w - 2, y + h - 25, 2, 12);
            
            // Основной кузов
            ctx.fillStyle = color;
            ctx.fillRect(x, y, w, h);
            
            // Кабина (крыша)
            ctx.fillStyle = shadeColor(color, -30);
            ctx.fillRect(x + 5, y + 20, w - 10, h - 40);
            
            // Лобовое стекло
            ctx.fillStyle = '#87CEEB';
            ctx.fillRect(x + 7, y + 22, w - 14, 15);
            
            // Заднее стекло
            ctx.fillRect(x + 7, y + h - 37, w - 14, 12);
            
            // Фары
            if (isPlayer) {
                ctx.fillStyle = '#FFFF00'; // Желтые фары спереди
                ctx.fillRect(x + 3, y, 8, 4);
                ctx.fillRect(x + w - 11, y, 8, 4);
                
                // Стоп-сигналы сзади
                ctx.fillStyle = '#FF0000';
                ctx.fillRect(x + 3, y + h - 4, 8, 4);
                ctx.fillRect(x + w - 11, y + h - 4, 8, 4);
            } else {
                // У врагов фары наоборот (они едут навстречу)
                ctx.fillStyle = '#FF0000';
                ctx.fillRect(x + 3, y + h - 4, 8, 4);
                ctx.fillRect(x + w - 11, y + h - 4, 8, 4);
                
                ctx.fillStyle = '#FFFF00';
                ctx.fillRect(x + 3, y, 8, 4);
                ctx.fillRect(x + w - 11, y, 8, 4);
            }
            
            // Бамперы
            ctx.fillStyle = '#333';
            ctx.fillRect(x - 1, y - 2, w + 2, 4);
            ctx.fillRect(x - 1, y + h - 2, w + 2, 4);
        }
        
        // Вспомогательная функция для затемнения цвета
        function shadeColor(color, percent) {
            let R = parseInt(color.substring(1,3),16);
            let G = parseInt(color.substring(3,5),16);
            let B = parseInt(color.substring(5,7),16);
            R = Math.min(255, Math.max(0, R + Math.round(R * percent / 100)));
            G = Math.min(255, Math.max(0, G + Math.round(G * percent / 100)));
            B = Math.min(255, Math.max(0, B + Math.round(B * percent / 100)));
            return "#" + ((1 << 24) + (R << 16) + (G << 8) + B).toString(16).slice(1);
        }
        
        function drawRoad() {
            // Трава
            ctx.fillStyle = '#2d5a27';
            ctx.fillRect(0, 0, canvas.width, canvas.height);
            
            // Обочина
            ctx.fillStyle = '#8B4513';
            ctx.fillRect(canvas.width/2 - 160, 0, 320, canvas.height);
            
            // Асфальт
            ctx.fillStyle = '#333';
            ctx.fillRect(canvas.width/2 - 150, 0, 300, canvas.height);
            
            // Разметка
            ctx.strokeStyle = '#FFF';
            ctx.lineWidth = 4;
            ctx.setLineDash([30, 30]);
            ctx.lineDashOffset = -roadOffset;
            
            ctx.beginPath();
            ctx.moveTo(canvas.width/2, 0);
            ctx.lineTo(canvas.width/2, canvas.height);
            ctx.stroke();
            
            // Бордюры
            ctx.setLineDash([]);
            ctx.fillStyle = (Math.floor(roadOffset / 40) % 2 === 0) ? '#FF0000' : '#FFFFFF';
            for(let i = -40; i < canvas.height; i += 40) {
                let y = (i + roadOffset % 40);
                ctx.fillRect(canvas.width/2 - 152, y, 4, 20);
                ctx.fillRect(canvas.width/2 + 148, y, 4, 20);
            }
        }
        
        function update() {
            if (!gameRunning) return;
            
            // Движение игрока
            if ((keys['ArrowLeft'] || keys['a'] || keys['A']) && player.x > canvas.width/2 - 145) {
                player.x -= 7;
            }
            if ((keys['ArrowRight'] || keys['d'] || keys['D']) && player.x < canvas.width/2 + 95) {
                player.x += 7;
            }
            
            // Движение дороги
            roadOffset += speed;
            score += 1;
            document.getElementById('score').innerText = Math.floor(score / 10);
            
            // Увеличение скорости
            if (score % 500 === 0) speed += 0.5;
            
            // Спавн врагов
            if (Math.random() < 0.02) {
                const lane = Math.random() > 0.5 ? 1 : -1;
                const enemyX = canvas.width/2 + (lane * 70) - 25;
                const colors = ['#FF0044', '#00D4FF', '#FFFF00', '#FF8800', '#AA00FF'];
                enemies.push({
                    x: enemyX,
                    y: -100,
                    width: 50,
                    height: 90,
                    color: colors[Math.floor(Math.random() * colors.length)]
                });
            }
            
            // Обновление врагов
            for (let i = enemies.length - 1; i >= 0; i--) {
                enemies[i].y += speed;
                
                // Проверка столкновений
                if (
                    player.x < enemies[i].x + enemies[i].width &&
                    player.x + player.width > enemies[i].x &&
                    player.y < enemies[i].y + enemies[i].height &&
                    player.y + player.height > enemies[i].y
                ) {
                    gameOver();
                }
                
                // Удаление врагов за экраном
                if (enemies[i].y > canvas.height) {
                    enemies.splice(i, 1);
                }
            }
        }
        
        function draw() {
            ctx.clearRect(0, 0, canvas.width, canvas.height);
            drawRoad();
            
            // Рисуем врагов
            enemies.forEach(e => drawCar(e.x, e.y, e.width, e.height, e.color));
            
            // Рисуем игрока
            drawCar(player.x, player.y, player.width, player.height, player.color, true);
        }
        
        function loop() {
            update();
            draw();
            requestAnimationFrame(loop);
        }
        
        function startGame() {
            document.getElementById('startScreen').classList.add('hidden');
            gameRunning = true;
            score = 0;
            speed = 5;
            enemies = [];
            player.x = canvas.width / 2 - 25;
        }
        
        function gameOver() {
            gameRunning = false;
            document.getElementById('finalScore').innerText = Math.floor(score / 10);
            document.getElementById('gameOverScreen').classList.remove('hidden');
        }
        
        function resetGame() {
            document.getElementById('gameOverScreen').classList.add('hidden');
            startGame();
        }
        
        // Запуск цикла
        loop();
        
        // Адаптация под размер экрана
        window.addEventListener('resize', () => {
            canvas.width = window.innerWidth > 800 ? 800 : window.innerWidth;
            player.x = canvas.width / 2 - 25;
        });
    </script>
</body>
</html>
